# Copy this to .env.local and fill in values from your Supabase project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by /admin and /api/admin/* routes.
# DO NOT prefix with NEXT_PUBLIC_; these must NEVER reach the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_PASSWORD=change-me-please
